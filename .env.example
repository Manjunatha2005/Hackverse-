# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ecosentinel

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SendGrid Email Alerts
SENDGRID_API_KEY=SG.your-sendgrid-key-here
ALERT_FROM_EMAIL=alerts@ecosentinel.io
GOVT_ALERT_EMAILS=dept@cpcb.gov.in,admin@govt.in
PUBLIC_ALERT_EMAILS=public-alerts@ecosentinel.io

# Twilio SMS Alerts
TWILIO_SID=ACyour-twilio-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
GOVT_PHONE_NUMBERS=+911234567890,+919876543210

# App
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
